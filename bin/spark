#!/usr/bin/env python3
# =============================================================================
# bin/spark - Spark StdCell 自动化框架 CLI 主入口
# 使用: spark <command> [options]
# =============================================================================
import argparse
import os
import sys
from pathlib import Path

# 源码运行：先把含 lib/ 的仓库根加入 sys.path；Nuitka standalone 无磁盘 lib/，由编译产物提供 import
_argv_dir = Path(sys.argv[0]).resolve().parent
for _root in filter(
    None,
    [
        Path(os.environ["SPARK_HOME"]).resolve()
        if os.environ.get("SPARK_HOME", "").strip()
        else None,
        _argv_dir,
        _argv_dir.parent,
    ],
):
    if (_root / "lib" / "core" / "runtime_paths.py").is_file():
        _s = str(_root)
        if _s not in sys.path:
            sys.path.insert(0, _s)
        break

from lib.core.runtime_paths import ensure_repo_on_syspath, get_spark_home  # noqa: E402

ensure_repo_on_syspath()

from lib.utils.logger import get_logger, setup_rich_logging
from lib.core.config_parser import SparkConfig
from lib.core.license_guard import run_pre_command_license_check
from lib.modules.init_env   import InitEnvComponent
from lib.modules.analysis   import AnalysisComponent
from lib.modules.porting_gds import PortingGdsComponent
from lib.modules.porting_lef import PortingLefComponent
from lib.modules.gen_gds    import GenGdsComponent
from lib.modules.gen_spice  import GenSpiceComponent
from lib.modules.gen_lib    import GenLibComponent
from lib.modules.gen_lef    import GenLefComponent
from lib.modules.gen_dft    import GenDftComponent
from lib.modules.release    import ReleaseComponent

setup_rich_logging()
logger = get_logger("spark")

# ---- 阶段注册表 ---------------------------------------------------------------
STAGE_MAP: dict[str, type] = {
    "init_env"  : InitEnvComponent,
    "analysis"     : AnalysisComponent,
    "porting_gds"  : PortingGdsComponent,
    "porting_lef"  : PortingLefComponent,
    "gen_gds"   : GenGdsComponent,
    "gen_spice" : GenSpiceComponent,
    "gen_lib"   : GenLibComponent,
    "gen_lef"   : GenLefComponent,
    "gen_dft"   : GenDftComponent,
    "release"   : ReleaseComponent,
}

ALL_STAGES = list(STAGE_MAP.keys())

# init_env 作为单条命令保持不变；其余阶段各拆为两条子命令
_SPLIT_STAGES = [s for s in ALL_STAGES if s != "init_env"]

# 命令名 -> (stage_name, action)
# action: "create_env" | "run" | "check" | "report" | "both"
_CMD_TABLE: dict[str, tuple[str, str]] = {"init_env": ("init_env", "both")}
for _s in _SPLIT_STAGES:
    _CMD_TABLE[f"create_{_s}_env"] = (_s, "create_env")
    _CMD_TABLE[f"run_{_s}"]        = (_s, "run")
    _CMD_TABLE[f"check_{_s}"]      = (_s, "check")
    _CMD_TABLE[f"report_{_s}"]     = (_s, "report")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="spark",
        description="Spark — StdCell 库自动化生成框架",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="\n".join([
            "示例:",
            "  spark -c proj.yaml init_env",
            "  spark -c proj.yaml create_gen_spice_env",
            "  spark -c proj.yaml run_gen_spice",
            "  spark -c proj.yaml check_gen_spice",
            "  spark -c proj.yaml report_gen_lib",
            "  spark -c proj.yaml run_all",
            "  spark -c proj.yaml run_all --from-stage gen_lib",
        ]),
    )
    parser.add_argument(
        "-c", "--config",
        required=True,
        metavar="YAML",
        help="项目配置文件路径 (必填)",
    )
    parser.add_argument(
        "-v", "--verbose",
        action="store_true",
        help="输出 DEBUG 级别日志",
    )

    subparsers = parser.add_subparsers(dest="command", metavar="COMMAND")

    # ---- init_env：单条命令（初始化整个工作区）---------------------------------
    subparsers.add_parser("init_env", help="初始化全局工作区环境")

    # ---- 其余阶段：各注册 4 条子命令 -----------------------------------------
    for stage in _SPLIT_STAGES:
        subparsers.add_parser(
            f"create_{stage}_env",
            help=f"创建 {stage} 阶段目录与脚本",
        )
        subparsers.add_parser(
            f"run_{stage}",
            help=f"执行 {stage} 阶段",
        )
        subparsers.add_parser(
            f"check_{stage}",
            help=f"校验 {stage} 阶段日志与产出文件",
        )
        subparsers.add_parser(
            f"report_{stage}",
            help=f"抽取 {stage} 阶段报告，写入 report/ 目录",
        )

    # ---- 全流程快捷命令 -------------------------------------------------------
    run_all_sp = subparsers.add_parser("run_all", help="顺序执行所有阶段（create_env + run）")
    run_all_sp.add_argument(
        "--from-stage",
        choices=ALL_STAGES,
        default=ALL_STAGES[0],
        metavar="STAGE",
        help="从指定阶段开始执行（跳过之前的阶段）",
    )

    return parser


def dispatch(args: argparse.Namespace, config: SparkConfig) -> None:
    """根据解析结果调度对应阶段组件。"""
    if args.command == "run_all":
        start_idx = ALL_STAGES.index(args.from_stage)
        for stage in ALL_STAGES[start_idx:]:
            logger.info(f"======  Stage: {stage}  ======")
            comp = STAGE_MAP[stage](config)
            comp.create_env()
            comp.run()
        return

    entry = _CMD_TABLE.get(args.command)
    if entry is None:
        logger.error("未指定执行命令，请运行 `spark --help` 查看帮助。")
        sys.exit(1)

    stage_name, action = entry
    comp = STAGE_MAP[stage_name](config)

    if action in ("create_env", "both"):
        comp.create_env()
    if action in ("run", "both"):
        comp.run()
    if action == "check":
        result = comp.check_result()
        sys.exit(0 if result.passed else 1)
    if action == "report":
        comp.extract_report()


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(0)

    run_pre_command_license_check(get_spark_home())

    try:
        config = SparkConfig(args.config)
    except FileNotFoundError as exc:
        logger.error(str(exc))
        sys.exit(1)
    except ValueError as exc:
        logger.error(str(exc))
        sys.exit(1)

    dispatch(args, config)


if __name__ == "__main__":
    main()
