#!/bin/csh -f
# =============================================================================
# Auto-generated by Spark StdCell Automation Framework
# Stage       : {{ stage }}
# Description : {{ description | default("N/A") }}
# Project     : {{ project_name }}
# Tech Node   : {{ tech_node }}
# =============================================================================
# DO NOT EDIT MANUALLY — changes will be overwritten by spark framework.
# =============================================================================

# ---------- 环境校验 -----------------------------------------------------------
if ( ! $?SPARK_HOME ) then
    echo "[ERROR] SPARK_HOME is not set. Please source spark.csh first."
    exit 1
endif

# ---------- 运行目录切换 -------------------------------------------------------
set RUN_DIR = "{{ run_dir | default('.') }}"
if ( ! -d $RUN_DIR ) mkdir -p $RUN_DIR
cd $RUN_DIR

# ---------- 日志目录 -----------------------------------------------------------
set LOG_DIR = "{{ log_dir | default('./log') }}"
if ( ! -d $LOG_DIR ) mkdir -p $LOG_DIR
set LOG_FILE = "$LOG_DIR/{{ stage }}{% if sub_stage is defined %}_{{ sub_stage }}{% endif %}.log"

echo "[INFO]  Stage     : {{ stage }}{% if sub_stage is defined %} / {{ sub_stage }}{% endif %}" | tee -a $LOG_FILE
echo "[INFO]  Start time: `date '+%Y-%m-%d %H:%M:%S'`" | tee -a $LOG_FILE
echo "[INFO]  Run dir   : $RUN_DIR" | tee -a $LOG_FILE

# ---------- 工具路径 -----------------------------------------------------------
{% if tool_cmd is defined %}
set TOOL_CMD = "{{ tool_cmd }}"
if ( ! -x `which $TOOL_CMD:t` ) then
    # 尝试直接以完整路径检查
    if ( ! -f "$TOOL_CMD" ) then
        echo "[WARN]  Tool not found: $TOOL_CMD" | tee -a $LOG_FILE
    endif
endif
{% endif %}

# ---------- PVT Corners（若适用）----------------------------------------------
{% if pvt_corners is defined and pvt_corners %}
set CORNERS = ( \
{% for corner in pvt_corners %}
    {{ corner }}{% if not loop.last %} \{% endif %}

{% endfor %}
)
echo "[INFO]  Corners   : $CORNERS" | tee -a $LOG_FILE
{% endif %}

# ---------- 输入/输出路径（若适用）-------------------------------------------
{% if gds_source is defined %}
set GDS_SOURCE    = "{{ gds_source }}"
{% endif %}
{% if netlist_source is defined %}
set NETLIST       = "{{ netlist_source }}"
{% endif %}
{% if output_gds is defined %}
set OUTPUT_GDS    = "{{ output_gds }}"
{% endif %}
{% if output_lib is defined %}
set OUTPUT_LIB    = "{{ output_lib }}"
{% endif %}
{% if output_lef is defined %}
set OUTPUT_LEF    = "{{ output_lef }}"
{% endif %}
{% if output_dft is defined %}
set OUTPUT_DFT    = "{{ output_dft }}"
{% endif %}

# ---------- 主体执行 -----------------------------------------------------------
echo "[INFO]  Executing {{ description | default(stage) }}..." | tee -a $LOG_FILE

{% if tool_cmd is defined %}
{{ tool_cmd }} \
    >>& $LOG_FILE

set EXIT_CODE = $status
{% else %}
# 此阶段无外部工具调用（由 Python 内部处理）
set EXIT_CODE = 0
{% endif %}

# ---------- 结果检查 -----------------------------------------------------------
echo "[INFO]  End time  : `date '+%Y-%m-%d %H:%M:%S'`" | tee -a $LOG_FILE
if ( $EXIT_CODE != 0 ) then
    echo "[ERROR] {{ stage }} failed with exit code: $EXIT_CODE" | tee -a $LOG_FILE
    exit $EXIT_CODE
else
    echo "[INFO]  {{ stage }} completed successfully." | tee -a $LOG_FILE
endif

exit 0
