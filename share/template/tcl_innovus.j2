##############################################################################
# Auto-generated by Spark StdCell Automation Framework
# Stage     : {{ stage }}
# Project   : {{ project_name }}
# Tech Node : {{ tech_node }}
# DO NOT EDIT MANUALLY
##############################################################################

# ---------- 全局变量 ----------------------------------------------------------
set DESIGN_NAME   "{{ project_name }}"
set TECH_NODE     "{{ tech_node }}"
set RUN_DIR       "{{ run_dir | default('.') }}"
set LOG_DIR       "{{ log_dir | default('./log') }}"

{% if gds_source is defined %}
set GDS_SOURCE    "{{ gds_source }}"
{% endif %}
{% if output_gds is defined %}
set OUTPUT_GDS    "{{ output_gds }}"
{% endif %}
{% if output_lef is defined %}
set OUTPUT_LEF    "{{ output_lef }}"
{% endif %}
{% if lef_source is defined %}
set LEF_SOURCE    "{{ lef_source }}"
{% endif %}

# ---------- 消息日志 ----------------------------------------------------------
proc spark_log { level msg } {
    set ts [clock format [clock seconds] -format "%Y-%m-%d %H:%M:%S"]
    puts "\[$ts\] \[$level\] $msg"
}

spark_log INFO "=== Spark Innovus Script Started ==="
spark_log INFO "Design : $DESIGN_NAME"
spark_log INFO "Tech   : $TECH_NODE"

# ---------- 读取技术文件（LEF）------------------------------------------------
{% if lef_source is defined %}
spark_log INFO "Reading LEF: $LEF_SOURCE"
read_physical -lef $LEF_SOURCE
{% endif %}

# ---------- 读取 GDS -----------------------------------------------------------
{% if gds_source is defined %}
spark_log INFO "Reading GDS: $GDS_SOURCE"
read_gds -lib $GDS_SOURCE -view layout
{% endif %}

# ---------- PVT Corner 设置 ---------------------------------------------------
{% if pvt_corners is defined and pvt_corners %}
{% for corner in pvt_corners %}
# Corner: {{ corner }}
spark_log INFO "Configuring corner: {{ corner }}"
{% endfor %}
{% endif %}

# ---------- GDS 导出（gen_gds 阶段专用）--------------------------------------
{% if output_gds is defined %}
spark_log INFO "Exporting merged GDS to: $OUTPUT_GDS"
set dbgdsout_options {
    -hierarchical
    -merge_file $OUTPUT_GDS
}
stream_out $OUTPUT_GDS \
    -lib_name $DESIGN_NAME \
    -view layout \
    -map_file ${SPARK_TMPL}/gds_layer.map

spark_log INFO "GDS export completed: $OUTPUT_GDS"
{% endif %}

# ---------- LEF 导出（porting_lef 等阶段）--------------------------------------
{% if output_lef is defined %}
spark_log INFO "Exporting ported LEF to: $OUTPUT_LEF"
# 选项依 Innovus 版本与 PDK 要求调整
write_lef $OUTPUT_LEF
spark_log INFO "LEF export completed: $OUTPUT_LEF"
{% endif %}

# ---------- 收尾 --------------------------------------------------------------
spark_log INFO "=== Spark Innovus Script Finished ==="
exit 0
